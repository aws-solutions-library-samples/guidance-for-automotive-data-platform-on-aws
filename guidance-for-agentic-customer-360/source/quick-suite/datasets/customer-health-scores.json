                                    "Expression": "ifelse(\n     avg_satisfaction_score < 3, '0-3',\n     avg_satisfaction_score < 5, '3-5',\n     avg_satisfaction_score < 7, '5-7',\n     avg_satisfaction_score < 9, '7-9',\n     '9-10'\n   )"
